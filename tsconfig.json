{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@reviewsense/types": ["packages/types/src"],
      "@reviewsense/utils": ["packages/utils/src"],
      "@reviewsense/ui": ["packages/ui/src"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
